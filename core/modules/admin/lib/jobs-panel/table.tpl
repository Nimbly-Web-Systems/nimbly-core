<div class="overflow-x-auto rounded-2xl border border-neutral-200 bg-white shadow-md">
    <table class="min-w-full text-sm">
        <caption class="sr-only">[#text Jobs#]</caption>
        <thead>
            <tr class="border-b border-neutral-200 bg-neutral-100/80 text-left text-xs uppercase tracking-wide text-neutral-500">
                <th scope="col" class="px-3 py-2 font-semibold">[#text Status#]</th>
                <th scope="col" class="px-3 py-2 font-semibold">[#text Type#]</th>
                <th scope="col" class="px-3 py-2 text-center font-semibold">[#text Attempts#]</th>
                <th scope="col" class="px-3 py-2 font-semibold">[#text Last error#]</th>
                <th scope="col" class="px-3 py-2 font-semibold">[#text Updated#]</th>
            </tr>
        </thead>
        <tbody>
            [#_jp.rows#]
        </tbody>
    </table>
</div>
