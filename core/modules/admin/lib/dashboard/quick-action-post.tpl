<form action="[#url [#_action.action#]#]" method="post" accept-charset="utf-8" id="[#_action.form_id#]" class="block w-full sm:inline sm:w-auto">
    [#form-key [#_action.form_id#]#]
    <button type="submit"
        class="inline-flex min-h-10 cursor-pointer items-center rounded-md border border-neutral-300 bg-white px-3 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-100 sm:min-h-0 sm:border-0 sm:bg-transparent sm:p-0 sm:underline sm:decoration-neutral-300 sm:hover:bg-transparent sm:hover:text-neutral-800 sm:hover:decoration-neutral-500">
        [#_action.label#]
    </button>
</form>
