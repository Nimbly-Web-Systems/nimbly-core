<form action="[#url [#_action.action#]#]" method="post" accept-charset="utf-8" id="[#_action.form_id#]" class="inline">
    [#form-key [#_action.form_id#]#]
    <button type="submit"
        class="cursor-pointer text-sm font-medium text-neutral-600 underline decoration-neutral-300 hover:text-neutral-800 hover:decoration-neutral-500">
        [#_action.label#]
    </button>
</form>
