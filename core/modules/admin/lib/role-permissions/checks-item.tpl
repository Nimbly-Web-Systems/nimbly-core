<label for="[#_item.id#]" class="flex items-center gap-3 rounded-md border border-neutral-200 bg-white px-3 py-2.5">
    [#_item.checkbox#]
    <span class="min-w-0">
        <span class="block font-medium text-neutral-800">[#_item.label#]</span>
        <span id="[#_item.id#]-desc" class="block text-xs text-neutral-500">[#_item.description#]</span>
    </span>
</label>
