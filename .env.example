# Nimbly site configuration
#
# Copy to .env and fill in values for the target environment.
# Do not commit .env.

# Environment label used by schedule:run and project code.
# Common values: prod, stage, dev.
APP_ENV=dev

# Required. Keep stable once data has been encrypted.
PEPPER=

# Optional. Only set this for alias/subdirectory setups.
# Root installs should omit BASE_PATH; / is the default.
# BASE_PATH=/mysite/

# Public canonical URL for CLI jobs that must generate absolute links.
# Required when scheduled/background jobs send email.
SITE_URL=

# Delay between processed background jobs. Keeps email bursts below provider rate limits.
JOB_RUN_DELAY_MS=250

# Email delivery. Required only when the site sends mail.
MAIL_SERVICE=resend
MAIL_FROM=
MAIL_FROM_NAME=
RESEND_API_KEY=

# Optional. Required only for AI-powered content features.
OPENAI_API_KEY=
