# Nimbly site configuration
# Copy this to .env and fill in values before running: php setup.php

# Base path for subdirectory installs (e.g. /mysite/ or leave as /)
BASE_PATH=/

# Pepper for password encryption (leave empty to auto-generate)
PEPPER=

# Resend email
RESEND_API_KEY=
MAIL_SERVICE=resend
MAIL_FROM=no-reply@mail.nimblyweb.com
MAIL_FROM_NAME=

# OpenAI (optional — required for AI content generation and translation)
OPENAI_API_KEY=
